rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: each user can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Patients collection: any authenticated staff member can read/write
    match /patients/{patientId} {
      allow read, write: if request.auth != null;
    }

    // Transcripts collection: any authenticated staff member can read/write
    match /transcripts/{transcriptId} {
      allow read, write: if request.auth != null;
    }

    // Clinic settings: any authenticated user can read; only admin writes (future-proofing)
    match /clinic/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
